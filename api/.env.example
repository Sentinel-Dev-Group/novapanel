# ─── App ────────────────────────────────────────────
APP_NAME=NovaPanel
APP_URL=http://localhost
APP_PORT=3000
NODE_ENV=development

# ─── Database (MariaDB) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=novapanel
DB_USER=novapanel
DB_PASS=

# ─── JWT Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ──────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (optional for now) ────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@novapanel.dev